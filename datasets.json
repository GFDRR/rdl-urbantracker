---
---
[{% for dataset in site.datasets %}
  {
    "external_url": {{ dataset.external_url | jsonify }},
    "title": {{ dataset.title | jsonify }},
    "datatypes": [{% for datatype_title in dataset.datatypes %}
      {% assign datatype = site.datatypes | where: "title", datatype_title | first %}
        {
          "category": {{ datatype.category | jsonify }},
          "title": {{ datatype.title | jsonify }}
        }{% unless forloop.last %},{% endunless %}{% endfor %}
    ]{% if dataset.notes != "" %},
    "notes": {{ dataset.notes | markdownify | jsonify }}{% endif %},
    "cities": [{% for city_id in dataset.cities %}
      {% assign city = site.cities | where: "city_id", city_id | first %}
        {
          "city_id": {{ city_id | jsonify }},
          "title": {{ city.title | jsonify }}
        }{% unless forloop.last %},{% endunless %}{% endfor %}
    ],
    "url": "{{ site.baseurl }}{{ dataset.url }}"
  }{% unless forloop.last %},{% endunless %}{% endfor %}
]
